# Cloudflare Pages — response headers
# Phase 2D · Trust harmonization

# HTML pages: short cache so deploys propagate fast and live-sentiment.html
# never serves stale JS hooks that don't match the deployed API contract.
/*.html
  Cache-Control: public, max-age=300, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Internal API endpoints intentionally NOT listed here — each Pages Function
# in /functions/api/ sets its own Cache-Control header (max-age 45 s for
# /api/market, 90 s for /api/sentiment, 420 s for /api/news). Overriding
# them via _headers would break edge caching.

# Static assets (favicons, images): long cache, immutable URLs.
/assets/*
  Cache-Control: public, max-age=2592000, immutable

# JS modules are loaded by UNVERSIONED dynamic import() and evolve across deploys.
# A more-specific rule (overrides the immutable rule above) so a redeploy is
# picked up and a once-cached bad/missing response cannot stick for 30 days —
# this is what otherwise breaks chart-vision-pro.js loading after a deploy.
/assets/*.js
  Cache-Control: public, max-age=3600, must-revalidate
  X-Content-Type-Options: nosniff

# AI CEO Operating System — private admin area, shares this Cloudflare Pages
# project with the public site (see ai-ceo-os/docs/decisions/
# DEC-002-cloudflare-shared-project.md). Never indexed, never cached publicly.
/ai-ceo-os/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: private, no-store
  X-Frame-Options: DENY
